# ================================================================
# .gitignore — Portfolio Project
# ================================================================

# ── API Keys & Secrets ──────────────────────────────────────────
# config.js holds the Gemini API key — NEVER commit this file.
config.js

# Environment variable files (if tooling is added later)
.env
.env.local
.env.development
.env.production
*.env

# ── Node.js ─────────────────────────────────────────────────────
# Package dependencies directory (Firebase CLI, build tools, etc.)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Firebase ─────────────────────────────────────────────────────
# Generated debug tokens — not sensitive, but not needed in repo
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# ── OS & Editor Artifacts ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.suo
*.user

# ── Build Output (if a build step is added later) ────────────────
dist/
build/
